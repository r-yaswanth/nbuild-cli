{
  "name": "nlearn-build",
  "version": "1.0.3",
  "description": "Interactive Flutter build TUI for nlearn",
  "type": "module",
  "bin": {
    "nbuild": "./dist/index.js"
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "start": "tsx src/index.ts",
    "build": "tsc && node -e \"const f='dist/index.js';const c=require('fs').readFileSync(f,'utf8');if(!c.startsWith('#!'))require('fs').writeFileSync(f,'#!/usr/bin/env node\\n'+c)\"",
    "pack": "npm run build && npm pack"
  },
  "dependencies": {
    "@clack/prompts": "^0.9.1",
    "@cli-prompts/multiline": "^1.0.0",
    "ink": "^6.8.0",
    "picocolors": "^1.1.1",
    "react": "^19.2.4"
  },
  "devDependencies": {
    "@types/node": "^22.19.11",
    "@types/react": "^19.2.14",
    "tsx": "^4.19.3",
    "typescript": "^5.7.3"
  }
}
